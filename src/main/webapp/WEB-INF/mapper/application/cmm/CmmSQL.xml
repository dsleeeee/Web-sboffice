<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    CmmSQL.xml
    공통쿼리 sql
    ======================================================
    No  ||  수정자 ||  수정일자    ||  수정내역
    ======================================================
    1       노현수     2018.10.24     주석생성, 포멧정리
-->
<mapper namespace="CmmSQL">

    <!-- 공통 쿼리 헤더 -->
    <!--
        TABLE    :
        PARAM    :
        COMMENTS : 쿼리 페이징 처리시 최상단 헤더에 include 한다.
    -->
    <sql id="PagingTemplateHeader">
        <![CDATA[
        SELECT
            TEMP.*
        FROM
            (
                 SELECT
                     ORG.*,
                     ROWNUM AS RNUM
                 FROM
                     (
        ]]>
    </sql>

    <!-- 공통쿼리 : 데이터 Count  -->
    <!--
        TABLE    :
        PARAM    :
        COMMENTS : 쿼리 페이징 처리시 내용 From 절 직전에 include 한다.
    -->
    <sql id="PagingTemplateCount">
        <![CDATA[
                , COUNT(*) OVER() AS TOT_CNT
        ]]>
    </sql>

    <!-- 공통 쿼리 Bottom -->
    <!--
        TABLE    :
        PARAM    :
        COMMENTS : 쿼리 페이징 처리시 최하단에 include 한다.
    -->
    <sql id="PagingTemplateBottom">
        <![CDATA[
                     ) ORG
                 WHERE
                     ROWNUM <= #{limit}
            ) TEMP
        WHERE
            TEMP.RNUM >= #{offset}
        ]]>
    </sql>

    <!-- 공통 쿼리 헤더 2 -->
    <!--
        TABLE    :
        PARAM    :
        COMMENTS : 쿼리 페이징 처리시 최상단 헤더에 include 한다.
    -->
    <sql id="PagingTemplateHeader2">
        <![CDATA[
             SELECT
                 ORG.*,
                 ROWNUM AS RNUM
             FROM
                 (
        ]]>
    </sql>
    <!-- 공통쿼리 : 데이터 Count2 -->
    <!--
        TABLE    :
        PARAM    :
        COMMENTS : 쿼리 페이징 처리시 내용 From 절 직전에 include 한다.
    -->
    <sql id="PagingTemplateCount2">
        <!--<if test='offset == 1'>-->
            <![CDATA[
                , COUNT(*) OVER() AS TOT_CNT
            ]]>
        <!--</if>-->
    </sql>

    <!-- 공통 쿼리 Bottom 2 -->
    <!--
        TABLE    :
        PARAM    :
        COMMENTS : 쿼리 페이징 처리시 최하단에 include 한다.
    -->
    <sql id="PagingTemplateBottom2">
        <![CDATA[
                ) ORG
                OFFSET #{offset} - 1 ROWS FETCH NEXT #{listScale} ROWS ONLY
        ]]>
    </sql>

</mapper>



